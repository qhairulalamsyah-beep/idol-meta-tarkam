// Prisma schema for WhatsApp Bot service
// This mirrors the main app's schema for standalone Railway deployment

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

// User Model - Players in the tournament
model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  gender       String   @default("male")
  tier         String   @default("B")
  points       Int      @default(0)
  avatar       String?
  phone        String?
  whatsappJid  String?
  discordId    String?
  role         String   @default("user")
  adminPass    String?
  permissions  String   @default("{}")
  isAdmin      Boolean  @default(false)
  isMVP        Boolean  @default(false)
  mvpScore     Int      @default(0)
  clubId       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  registrations Registration[]
  teamMembers   TeamMember[]
  rankings      Ranking[]
  donations     Donation[]
  mvpMatches    Match[]  @relation("MatchMVP")
  playerStats   PlayerMatchStat[]
  character     Character?
  club          Club?      @relation(fields: [clubId], references: [id], onDelete: SetNull)

  @@index([gender])
  @@index([role])
  @@index([clubId])
}

model Tournament {
  id            String   @id @default(cuid())
  name          String
  division      String
  type          String
  status        String   @default("setup")
  week          Int?
  bracketType   String?
  prizePool     Float   @default(0)
  basePrizePool Float   @default(0)
  mode          String   @default("GR Arena 3vs3")
  bpm           String   @default("130")
  lokasi        String   @default("PUB 1")
  startDate     DateTime?
  endDate       DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  registrations Registration[]
  teams         Team[]
  matches       Match[]
  sawers        Sawer[]

  @@index([division])
  @@index([status])
}

model Registration {
  id           String   @id @default(cuid())
  userId       String
  tournamentId String
  status       String   @default("pending")
  tierAssigned String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([userId, tournamentId])
  @@index([tournamentId])
  @@index([status])
}

model Team {
  id              String   @id @default(cuid())
  tournamentId    String
  name            String
  seed            Int      @default(0)
  isEliminated    Boolean  @default(false)
  eliminationType String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tournament     Tournament  @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  members        TeamMember[]
  matchesAsTeamA Match[]     @relation("TeamA")
  matchesAsTeamB Match[]     @relation("TeamB")
  wonMatches     Match[]     @relation("MatchWinnerTeam")

  @@index([tournamentId])
}

model TeamMember {
  id     String @id @default(cuid())
  teamId String
  userId String
  role   String @default("member")

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

model Match {
  id           String    @id @default(cuid())
  tournamentId String
  round        Int       @default(1)
  matchNumber  Int       @default(1)
  teamAId      String?
  teamBId      String?
  scoreA       Int?
  scoreB       Int?
  winnerId     String?
  mvpId        String?
  status       String    @default("pending")
  bracket      String    @default("winners")
  scheduledAt  DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tournament  Tournament   @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  teamA       Team?        @relation("TeamA", fields: [teamAId], references: [id], onDelete: SetNull)
  teamB       Team?        @relation("TeamB", fields: [teamBId], references: [id], onDelete: SetNull)
  winner      Team?        @relation("MatchWinnerTeam", fields: [winnerId], references: [id], onDelete: SetNull)
  mvp         User?        @relation("MatchMVP", fields: [mvpId], references: [id], onDelete: SetNull)
  playerStats PlayerMatchStat[]

  @@index([tournamentId])
  @@index([status])
}

model Ranking {
  id     String @id @default(cuid())
  userId String
  points Int    @default(0)
  wins   Int    @default(0)
  losses Int    @default(0)
  rank   Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
}

model Donation {
  id             String    @id @default(cuid())
  userId         String?
  donorName      String?
  amount         Float
  message        String?
  anonymous      Boolean   @default(false)
  paymentMethod  String    @default("qris")
  paymentStatus  String    @default("pending")
  proofImageUrl  String?
  paidAt         DateTime?
  createdAt      DateTime  @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([paymentStatus])
}

model Sawer {
  id               String    @id @default(cuid())
  tournamentId     String?
  senderName       String
  senderAvatar     String?
  targetPlayerId   String?
  targetPlayerName String?
  amount           Float
  message          String?
  paymentMethod    String    @default("qris")
  paymentStatus    String    @default("pending")
  proofImageUrl    String?
  paidAt           DateTime?
  createdAt        DateTime  @default(now())

  tournament      Tournament? @relation(fields: [tournamentId], references: [id], onDelete: SetNull)

  @@index([paymentStatus])
}

model Character {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  gender    String    @default("male")
  universe  String
  alignment String
  classType String
  colors    String
  imageUrl  String?
  isTaken   Boolean   @default(false)
  takenBy   String?   @unique
  takenAt   DateTime?

  user User? @relation(fields: [takenBy], references: [id], onDelete: SetNull)

  @@index([gender])
}

model Club {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members User[]
}

model Settings {
  id          String  @id @default(cuid())
  key         String  @unique
  value       String
  description String?
}

model ActivityLog {
  id        String   @id @default(cuid())
  action    String
  details   String?
  userId    String?
  createdAt DateTime @default(now())

  @@index([action])
}

model PlayerMatchStat {
  id      String @id @default(cuid())
  matchId String
  userId  String
  score   Int    @default(0)

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([matchId, userId])
}

model BotLog {
  id            String   @id @default(cuid())
  platform      String
  command       String
  sender        String?
  senderId      String?
  response      String?
  success       Boolean  @default(true)
  tournamentId  String?
  createdAt     DateTime @default(now())

  @@index([platform])
  @@index([command])
}

model WhatsAppSettings {
  id                     String    @id @default(cuid())
  provider               String    @default("baileys")
  isActive               Boolean   @default(true)
  metaAccessToken        String?
  metaPhoneNumberId      String?
  metaBusinessAccountId  String?
  metaWebhookVerifyToken String?
  metaAppSecret          String?
  metaApiEnabled         Boolean   @default(false)
  baileysEnabled         Boolean   @default(true)
  lastConnectedAt        DateTime?
  connectionStatus       String    @default("disconnected")
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
}
